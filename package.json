{
  "name": "ip-devicer",
  "version": "0.1.0",
  "type": "module",
  "description": "IP Intelligence Middleware for the FP-Devicer Intelligence Suite",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js",
      "default": "./dist/main.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc --outDir dist",
    "test": "npx vitest run",
    "test:watch": "npx vitest watch",
    "test:coverage": "npx vitest run --coverage"
  },
  "keywords": ["ip", "geolocation", "fingerprinting", "middleware", "maxmind"],
  "author": "Gateway Corporate Solutions",
  "license": "SEE LICENSE IN license.txt",
  "dependencies": {
    "@maxmind/geoip2-node": "^6.3.4",
    "ipaddr.js": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^18.15.11",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.4.5",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "devicer.js": "^1.5.9"
  },
  "peerDependenciesMeta": {
    "devicer.js": {
      "optional": true
    }
  }
}
